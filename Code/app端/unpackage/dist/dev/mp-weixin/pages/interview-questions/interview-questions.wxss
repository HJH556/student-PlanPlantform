
.container.data-v-5b2a5f3d {
    min-height: 100vh;
    background: #f5f7fa;
    padding: 20rpx;
}

/* 页面头部 */
.page-header.data-v-5b2a5f3d {
    background: linear-gradient(135deg, #1a237e 0%, #283593 100%);
    border-radius: 20rpx;
    padding: 40rpx 30rpx;
    margin-bottom: 30rpx;
    color: white;
}
.header-content.data-v-5b2a5f3d {
    display: flex;
    flex-direction: column;
    align-items: center;
}
.page-badge.data-v-5b2a5f3d {
    background: rgba(255, 255, 255, 0.2);
    padding: 8rpx 16rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
    margin-bottom: 20rpx;
}
.page-title.data-v-5b2a5f3d {
    font-size: 36rpx;
    font-weight: 600;
    margin-bottom: 10rpx;
}
.page-subtitle.data-v-5b2a5f3d {
    font-size: 28rpx;
    opacity: 0.9;
    text-align: center;
}

/* 职业选择 */
.job-selection.data-v-5b2a5f3d {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
}
.section-title.data-v-5b2a5f3d {
    font-size: 32rpx;
    font-weight: 600;
    margin-bottom: 10rpx;
    color: #1e293b;
}
.section-desc.data-v-5b2a5f3d {
    font-size: 26rpx;
    color: #64748b;
    margin-bottom: 20rpx;
}
.job-buttons.data-v-5b2a5f3d {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
}
.job-btn.data-v-5b2a5f3d {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 30rpx;
    background: #f8fafc;
    border: 2rpx solid #e2e8f0;
    border-radius: 16rpx;
    transition: all 0.3s ease;
}
.job-btn.active.data-v-5b2a5f3d {
    background: #1a237e;
    border-color: #1a237e;
    color: white;
}
.job-title.data-v-5b2a5f3d {
    font-size: 28rpx;
    font-weight: 500;
}
.match-score.data-v-5b2a5f3d {
    font-size: 24rpx;
    font-weight: 600;
}
.job-btn.active .match-score.data-v-5b2a5f3d {
    color: #ffd700;
}

/* 面试问题容器 */
.questions-container.data-v-5b2a5f3d {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
}
.questions-header.data-v-5b2a5f3d {
    margin-bottom: 30rpx;
}
.ai-status.data-v-5b2a5f3d {
    display: flex;
    align-items: center;
    gap: 20rpx;
    margin: 20rpx 0;
}
.status-badge.data-v-5b2a5f3d {
    padding: 8rpx 16rpx;
    border-radius: 20rpx;
    font-size: 24rpx;
    font-weight: 500;
}
.status-badge.ai-enabled.data-v-5b2a5f3d {
    background: #d1fae5;
    color: #065f46;
}
.status-badge.ai-disabled.data-v-5b2a5f3d {
    background: #fef3c7;
    color: #92400e;
}
.status-hint.data-v-5b2a5f3d {
    font-size: 24rpx;
    color: #64748b;
}
.error-message.data-v-5b2a5f3d {
    color: #dc2626;
    font-size: 26rpx;
    background: #fef2f2;
    padding: 16rpx 20rpx;
    border-radius: 12rpx;
    border-left: 4rpx solid #dc2626;
}

/* 加载状态 */
.loading-container.data-v-5b2a5f3d {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60rpx 0;
}
.loading-spinner.data-v-5b2a5f3d {
    width: 60rpx;
    height: 60rpx;
    border: 4rpx solid #e2e8f0;
    border-top: 4rpx solid #1a237e;
    border-radius: 50%;
    animation: spin-5b2a5f3d 1s linear infinite;
    margin-bottom: 30rpx;
}
@keyframes spin-5b2a5f3d {
0% { transform: rotate(0deg);
}
100% { transform: rotate(360deg);
}
}

/* 问题列表 */
.questions-list.data-v-5b2a5f3d {
    display: flex;
    flex-direction: column;
    gap: 30rpx;
}
.question-card.data-v-5b2a5f3d {
    border: 2rpx solid #e2e8f0;
    border-radius: 16rpx;
    overflow: hidden;
}
.question-header.data-v-5b2a5f3d {
    display: flex;
    align-items: center;
    padding: 24rpx 30rpx;
    background: #f8fafc;
    cursor: pointer;
}
.question-number.data-v-5b2a5f3d {
    background: #1a237e;
    color: white;
    width: 40rpx;
    height: 40rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24rpx;
    font-weight: 600;
    margin-right: 20rpx;
}
.question-text.data-v-5b2a5f3d {
    flex: 1;
    font-size: 28rpx;
    font-weight: 500;
    color: #1e293b;
}
.toggle-icon.data-v-5b2a5f3d {
    font-size: 24rpx;
    color: #64748b;
    transition: transform 0.3s ease;
}
.toggle-icon.rotated.data-v-5b2a5f3d {
    transform: rotate(180deg);
}
.question-content.data-v-5b2a5f3d {
    padding: 30rpx;
}
.question-meta.data-v-5b2a5f3d {
    display: flex;
    gap: 30rpx;
    margin-bottom: 20rpx;
}
.question-type.data-v-5b2a5f3d, .question-difficulty.data-v-5b2a5f3d {
    font-size: 24rpx;
    color: #64748b;
    background: #f1f5f9;
    padding: 8rpx 16rpx;
    border-radius: 12rpx;
}

/* 用户回答区域 */
.user-answer-section.data-v-5b2a5f3d {
    margin: 30rpx 0;
    padding: 20rpx 0;
    border-top: 2rpx solid #f1f5f9;
    border-bottom: 2rpx solid #f1f5f9;
}
.answer-title.data-v-5b2a5f3d {
    font-size: 26rpx;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 20rpx;
}
.answer-input.data-v-5b2a5f3d {
    width: 100%;
    min-height: 200rpx;
    padding: 20rpx;
    border: 2rpx solid #e2e8f0;
    border-radius: 12rpx;
    font-size: 26rpx;
    background: #f8fafc;
    margin-bottom: 20rpx;
}
.answer-actions.data-v-5b2a5f3d {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.evaluate-btn.data-v-5b2a5f3d {
    background: #1a237e;
    color: white;
    border: none;
    padding: 16rpx 32rpx;
    border-radius: 12rpx;
    font-size: 26rpx;
    font-weight: 500;
}
.evaluate-btn.data-v-5b2a5f3d:disabled {
    background: #cbd5e1;
    color: #64748b;
}
.answer-length.data-v-5b2a5f3d {
    font-size: 24rpx;
    color: #64748b;
}

/* 参考答案 */
.reference-answer.data-v-5b2a5f3d {
    margin: 30rpx 0;
}
.answer-content.data-v-5b2a5f3d {
    background: #f0f9ff;
    padding: 20rpx;
    border-radius: 12rpx;
    border-left: 4rpx solid #0ea5e9;
    font-size: 26rpx;
    line-height: 1.6;
    color: #0369a1;
}

/* 评估结果 */
.evaluation-result.data-v-5b2a5f3d {
    background: #f0fdf4;
    padding: 20rpx;
    border-radius: 12rpx;
    border: 2rpx solid #bbf7d0;
}
.evaluation-title.data-v-5b2a5f3d {
    font-size: 26rpx;
    font-weight: 600;
    color: #166534;
    margin-bottom: 20rpx;
}
.score-section.data-v-5b2a5f3d {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 15rpx;
}
.score-label.data-v-5b2a5f3d {
    font-size: 26rpx;
    color: #166534;
}
.score-value.data-v-5b2a5f3d {
    font-size: 28rpx;
    font-weight: 600;
    color: #dc2626;
}
.section-label.data-v-5b2a5f3d {
    font-size: 24rpx;
    font-weight: 500;
    color: #166534;
    margin-bottom: 8rpx;
}
.section-content.data-v-5b2a5f3d {
    font-size: 26rpx;
    color: #15803d;
    line-height: 1.5;
}
.strengths-section.data-v-5b2a5f3d, .weaknesses-section.data-v-5b2a5f3d, .suggestions-section.data-v-5b2a5f3d {
    margin-bottom: 15rpx;
}

/* 无职业选择提示 */
.no-job-selected.data-v-5b2a5f3d {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 400rpx;
}
.no-job-content.data-v-5b2a5f3d {
    text-align: center;
}
.no-job-icon.data-v-5b2a5f3d {
    font-size: 80rpx;
    margin-bottom: 20rpx;
}
.no-job-title.data-v-5b2a5f3d {
    font-size: 32rpx;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 10rpx;
}
.no-job-desc.data-v-5b2a5f3d {
    font-size: 26rpx;
    color: #64748b;
}
